environment = "production"
region      = "europe-west2"
veo_location = "global"
veo_model_id = "veo-3.1-generate-001"
campaign_media_work_retention_days = 30

# Add an OAuth token version to the GCP Secret Manager secret `instagram-access-token`
# before enabling. Keep the token itself out of tfvars and OpenTofu state.
instagram_publishing_enabled = false
# instagram_user_id          = "17841400000000000"
# instagram_graph_api_version = "vNN.0"

# Set an explicit GCP project ID when using an existing project or when the derived
# default is unavailable. With create_gcp_project=true and project_id left empty,
# OpenTofu derives "ipace-owners-production".
# project_id        = "replace-with-production-project-id"
# project_id_prefix = "ipace-owners"
# quota_project     = "ipace-owners-production"

# Set true if OpenTofu should create the GCP project. Leave false to use an existing project.
create_gcp_project = false
# project_name      = "I-PACE Owners Production"
firebase_project_display_name = "I-PACE Owners"
# gcp_org_id        = "replace-with-org-id"
# gcp_folder_id     = "replace-with-folder-id"
# billing_account   = "000000-000000-000000"

github_owner = "dgem"
github_repo  = "ipace-owners"

# dan@kanzi.co.uk is always included by the shared module and resolved to this
# environment's UID after sign-in. Add any further admins here; the set is authoritative.
manage_firebase_admins = true
firebase_admin_users = {
  # another_admin = "person@example.org"
}

allowed_origins = "https://ipace-owners.org,https://www.ipace-owners.org"
site_url        = "https://ipace-owners.org/member/account/"
# firebase_auth_authorized_domains = ["www.ipace-owners.org"]

# Isolate automated authentication mail from the apex domain's human mailboxes.
# Firebase supplies TXT/CNAME records after the first apply. Add them at Fasthosts;
# do not change the apex MX records. Then run: make infra-email-domain ENV=production
firebase_auth_email_domain        = "auth.ipace-owners.org"
firebase_auth_email_action_domain = "ipace-owners.org"

# Set bootstrap_resend_api_key_secret=true and provide the real API key via
# TF_VAR_resend_api_key or an uncommitted tfvars file if OpenTofu should bootstrap
# the GitHub environment secret RESEND_API_KEY_PRODUCTION. Leave false if you
# manage that GitHub secret manually.

# bootstrap_resend_api_key_secret = true
# resend_api_key = "re_replace_with_production_resend_api_key"
resend_from           = "I-PACE Owners <members@ipace-owners.org>"
resend_reply_to       = "contact@ipace-owners.org"
resend_asset_base_url = "https://ipace-owners.org"
manage_resend_domain  = true
resend_domain         = "ipace-owners.org"
resend_region         = "eu-west-1"

# The apex is canonical; Firebase Hosting redirects www after both domains validate.
firebase_hosting_custom_domains = {
  "ipace-owners.org"     = {}
  "www.ipace-owners.org" = { redirect_target = "ipace-owners.org" }
}

manage_github_actions = true

# Set the real secret value via environment variables or an uncommitted tfvars file:
# TF_VAR_vin_pepper=...
