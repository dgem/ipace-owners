project_id = "replace-with-staging-project-id"
region     = "europe-west2"

github_owner = "dgem"
github_repo  = "ipace-owners"

allowed_origins = "https://replace-with-staging-project.web.app,http://localhost:8080,http://localhost:5000"

firebase_auth_domain        = "replace-with-staging-project.firebaseapp.com"
firebase_app_id             = "replace-with-staging-web-app-id"
firebase_storage_bucket     = "replace-with-staging-project.appspot.com"
firebase_email_continue_url = "https://replace-with-staging-project.web.app/account/"

manage_github_actions = true

# Set real values via environment variables or an uncommitted tfvars file:
# TF_VAR_firebase_web_api_key=...
# TF_VAR_vin_pepper=...
