{
  "name": "ipace-owners",
  "version": "0.1.0",
  "description": "I-PACE Owners' Advocacy Group website",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "eleventy --serve",
    "build": "eleventy",
    "clean": "rm -rf _site",
    "lint:js": "eslint .eleventy.js scripts test src/assets/js",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:markdown": "markdownlint-cli2",
    "lint:data": "prettier --check \"**/*.{json,yaml,yml}\" \"!node_modules/**\" \"!_site/**\" \"!firebase-preview.json\"",
    "test": "node --test",
    "test:visual": "node scripts/visual-check.mjs",
    "smoke:deployment": "node scripts/smoke-test-deployment.mjs"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "fast-xml-parser": "^5.10.1",
    "firebase-tools": "^15.24.0",
    "globals": "^17.7.0",
    "markdownlint-cli2": "^0.23.1",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0"
  }
}
