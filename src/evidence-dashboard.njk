            <span class="bar-chart__label">2018</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:20%"></div></div>
            <span class="bar-chart__value">20%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">2019</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:28%"></div></div>
            <span class="bar-chart__value">28%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">2020</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:22%"></div></div>
            <span class="bar-chart__value">22%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">2021</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:18%"></div></div>
            <span class="bar-chart__value">18%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">2022+</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:12%"></div></div>
            <span class="bar-chart__value">12%</span>
          </div>
        </div>
        <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-3);margin-bottom:0;">Illustrative data only</p>
      </div>

      <div class="chart-panel">
        <h3 class="chart-panel__title">Recall completion status (H570/H571/H572)</h3>
        <div class="bar-chart" role="img" aria-label="Placeholder recall completion chart">
          <div class="bar-chart__row">
            <span class="bar-chart__label">Completed</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:48%"></div></div>
            <span class="bar-chart__value">48%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">Booked</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:15%"></div></div>
