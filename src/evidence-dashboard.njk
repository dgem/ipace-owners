          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">No loan car</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:40%"></div></div>
            <span class="bar-chart__value">40%</span>
          </div>
        </div>
        <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-3);margin-bottom:0;">Illustrative data only</p>
      </div>

      <div class="chart-panel">
        <h3 class="chart-panel__title">Battery warranty status at time of fault</h3>
        <div class="bar-chart" role="img" aria-label="Placeholder warranty status chart">
          <div class="bar-chart__row">
            <span class="bar-chart__label">Inside 8yr/100k</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:65%"></div></div>
            <span class="bar-chart__value">65%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">Outside 8yr/100k</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:28%"></div></div>
            <span class="bar-chart__value">28%</span>
          </div>
          <div class="bar-chart__row">
            <span class="bar-chart__label">Unknown</span>
            <div class="bar-chart__track"><div class="bar-chart__fill" style="width:7%"></div></div>
            <span class="bar-chart__value">7%</span>
          </div>
        </div>
        <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-3);margin-bottom:0;">Illustrative data only. Inferred from vehicle age and mileage at time of fault report.</p>
      </div>

      <div class="chart-panel">
