---
layout: base.njk
title: Member Dashboard
description: "Member dashboard — I-PACE Owners' Advocacy Group."
permalink: /member/dashboard/
---

<div class="page-header">
  <div class="container">
    <p class="page-header__eyebrow">Members</p>
    <h1 class="page-header__title">Member Dashboard</h1>
  </div>
</div>

<div class="section">
  <div class="container">

    <!-- Server-side auth container: member-auth.js verifies via /api/member-data -->
    <div data-auth-container>

      <!-- Login gate — shown by default when server confirms not authenticated -->
      <div class="auth-gate" data-auth-pending>
        <h2 class="auth-gate__title">Checking sign-in...</h2>
        <p class="auth-gate__body">One moment while we confirm your member session.</p>
      </div>

      <!-- Login gate — shown after server confirms not authenticated -->
      <div class="auth-gate" data-auth-login-gate hidden>
        <div class="auth-gate__icon" aria-hidden="true">🔒</div>
        <h2 class="auth-gate__title">Members only</h2>
        <p class="auth-gate__body">
          Enter your email address and we will send a secure sign-in link to access the member dashboard.
        </p>
        <form class="magic-link-form" data-magic-link-form>
          <label for="dashboard-magic-email">Email address</label>
          <input id="dashboard-magic-email" name="email" type="email" autocomplete="email" required>
          <button class="btn btn--primary full-width" type="submit">Email me a sign-in link</button>
          <p class="form-hint" data-magic-link-status role="status" aria-live="polite"></p>
        </form>
        <p class="form-hint" style="margin-top: var(--space-3);">
          Not a member yet? <a href="/join/">Join the group</a> first.
        </p>
      </div>

      <!-- Content — revealed by member-auth.js after server confirms auth -->
      <div class="auth-content" data-auth-content hidden>

        <section class="member-workspace" data-vehicle-workspace aria-labelledby="vehicle-workspace-title">
          <div class="member-workspace__loading" data-vehicle-workspace-loading>
            <h2 id="vehicle-workspace-title">Your vehicles</h2>
            <p>Loading your vehicle records...</p>
          </div>
          <div data-vehicle-workspace-content hidden>
            <div class="vehicle-tabs-row">
              <div class="vehicle-tabs" role="tablist" aria-label="Your vehicles" data-vehicle-tabs></div>
              <a href="/submit-vehicle-data/" class="btn btn--sm btn--primary">Add vehicle</a>
            </div>
            <div data-active-vehicle></div>
          </div>
        </section>

        <div class="member-secondary-grid">
          <section class="dashboard-panel">
            <div class="dashboard-panel__header">
              <h2 class="dashboard-panel__title">Your membership</h2>
            </div>
            <div data-join-container>
              <div data-join-info>
                <p style="color:var(--color-text-muted);">Loading...</p>
              </div>
            </div>
          </section>

          <section class="dashboard-panel">
            <div class="dashboard-panel__header">
              <h2 class="dashboard-panel__title">Group updates</h2>
            </div>
            <p style="color:var(--color-text-muted);">
              Check the <a href="/updates/">Updates page</a> for the latest news.
            </p>
          </section>
        </div>
      </div>
    </div>

  </div>
</div>
