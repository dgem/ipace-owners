---
layout: form-page.njk
title: Register Vehicle Basics
eyebrow: Evidence
subtitle: "Add an I-PACE to your account with vehicle identity and battery health details."
description: "Register basic I-PACE vehicle and battery health data with the owners' advocacy group evidence base."
multiStepForm: true
---

<!-- Server-side auth container: member-auth.js verifies via /api/member-data -->
<div data-auth-container>

	<!-- Login gate — shown by default when server confirms not authenticated -->
	<div class="auth-gate" data-auth-pending>
		<h2 class="auth-gate__title">Checking sign-in...</h2>
		<p class="auth-gate__body">One moment while we confirm your member session.</p>
	</div>

	<!-- Login gate — shown after server confirms not authenticated -->
	<div class="auth-gate" data-auth-login-gate hidden>
		<div class="auth-gate__icon" aria-hidden="true">🔒</div>
		<h2 class="auth-gate__title">Sign in to register vehicle data</h2>
		<p class="auth-gate__body">
		Vehicle basics are linked to your member account so you can manage them later.
		If you own, owned, or help with more than one I-PACE, add each vehicle separately.
		</p>
		<form class="magic-link-form" data-magic-link-form>
			<label for="vehicle-magic-email">Email address</label>
			<input id="vehicle-magic-email" name="email" type="email" autocomplete="email" required>
			<button class="btn btn--primary full-width" type="submit">Email me a sign-in link</button>
			<p class="form-hint" data-magic-link-status role="status" aria-live="polite"></p>
		</form>
		<p class="form-hint" style="margin-top: var(--space-3);">
			Not a member yet? <a href="/join/">Join the group</a> first.
		</p>
	</div>

	<!-- Content — revealed by member-auth.js after server confirms auth -->
	<div class="auth-content" data-auth-content hidden>
	<form
		class="form"
		style="max-width: none;"
		name="vehicle-basics"
		method="POST"
		action="/api/submit-vehicle-basics"
		data-multistep-form
		data-database-submit="/api/submit-vehicle-basics"
		data-database-requires-auth
		novalidate
		aria-label="Register I-PACE vehicle basics"
	>

		<div class="progress-indicator" data-progress aria-live="polite" aria-atomic="true">
			<div class="progress-indicator__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-label="Form progress">
				<div class="progress-indicator__fill" data-progress-fill style="width: 50%;"></div>
			</div>
			<div class="progress-indicator__text">
				<span data-progress-text>Step 1 of 2</span>
				<span>Vehicle basics</span>
			</div>
		</div>

		<div data-step="1">
			<h2 class="step-heading" data-step-heading tabindex="-1">Vehicle details</h2>

			<fieldset data-require-one="vin registration">
				<legend>About your I-PACE</legend>
				<p class="form-error" data-require-one-error role="alert" hidden>Provide either the VIN or registration before continuing.</p>

				<div class="two-column">
					<div class="form-group">
						<label for="vin">VIN</label>
						<input type="text" id="vin" name="vin" maxlength="25" autocomplete="off" aria-describedby="vin-hint vin-error vin-warning" data-vin-identifier data-vin-optional-with="registration">
						<span class="form-hint" id="vin-hint">Optional 17-character Vehicle Identification Number. Spaces and hyphens are ignored. You can find it on the V5C/log book, windscreen plate, or Jaguar app. Full VINs are never stored.</span>
						<span class="form-error" id="vin-error" role="alert" hidden>VIN must be 17 characters and cannot contain I, O, or Q. Leave it blank if you are using registration instead.</span>
						<span class="form-warning" id="vin-warning" data-vin-warning hidden>This does not look like a typical Jaguar/JLR VIN. You can continue if it is correct.</span>
					</div>

					<div class="form-group">
						<label for="registration">Registration / plate</label>
						<input type="text" id="registration" name="registration" autocomplete="off" aria-describedby="registration-hint registration-warning" data-uk-registration data-country-field="country">
						<span class="form-hint" id="registration-hint">Provide either the registration or VIN so we can identify the vehicle record. UK plates are checked as guidance only.</span>
						<span class="form-warning" id="registration-warning" data-uk-registration-warning hidden>This does not look like a common UK registration format. You can continue if it is correct.</span>
					</div>

					<div class="form-group">
						<label for="country">Country</label>
						<select id="country" name="country">
							<option value="">Select country</option>
							<option value="GB" selected>United Kingdom</option>
							<option value="IE">Ireland</option>
							<option value="DE">Germany</option>
							<option value="FR">France</option>
							<option value="NL">Netherlands</option>
							<option value="NO">Norway</option>
							<option value="SE">Sweden</option>
							<option value="DK">Denmark</option>
							<option value="AT">Austria</option>
							<option value="CH">Switzerland</option>
							<option value="BE">Belgium</option>
							<option value="ES">Spain</option>
							<option value="IT">Italy</option>
							<option value="PT">Portugal</option>
							<option value="US">United States</option>
							<option value="CA">Canada</option>
							<option value="AU">Australia</option>
							<option value="NZ">New Zealand</option>
							<option value="other">Other</option>
						</select>
					</div>

					<div class="form-group">
						<label for="model-year">Model year</label>
						<select id="model-year" name="modelYear">
							<option value="">Select year</option>
							<option>2018</option>
							<option>2019</option>
							<option>2020</option>
							<option>2021</option>
							<option>2022</option>
							<option>2023</option>
							<option>2024</option>
						</select>
					</div>

					<div class="form-group">
						<label for="mileage">Current mileage</label>
						<input type="number" id="mileage" name="mileage" min="0" max="500000" aria-describedby="mileage-hint">
						<span class="form-hint" id="mileage-hint">Use miles for now. Kilometre support will be added with the fuller evidence form.</span>
					</div>

					<div class="form-group">
						<label for="owned-since">Owned since</label>
						<input type="date" id="owned-since" name="ownedSince" aria-describedby="owned-since-error" data-not-future>
						<span class="form-error" id="owned-since-error" role="alert" hidden>Owned since cannot be in the future.</span>
					</div>

					<div class="form-group">
						<label for="first-reg">First registration date <span style="font-weight:400; color: var(--color-text-muted);">(if known)</span></label>
						<input type="date" id="first-reg" name="firstReg" aria-describedby="first-reg-error" data-not-future>
						<span class="form-error" id="first-reg-error" role="alert" hidden>First registration date cannot be in the future.</span>
					</div>
				</div>
			</fieldset>

			<div class="step-nav">
				<button type="button" class="btn btn--secondary" data-prev style="visibility:hidden">Back</button>
				<button type="button" class="btn btn--primary" data-next>Next: Battery health →</button>
			</div>
		</div>

		<div data-step="2" class="step--hidden">
			<h2 class="step-heading" data-step-heading tabindex="-1">Battery health</h2>

			<fieldset>
				<legend>State of Health</legend>
				<p class="form-hint">If you do not know the State of Health, leave these fields blank and submit the vehicle basics.</p>

				<div class="two-column">
					<div class="form-group">
						<label for="soh">Current State of Health (%) <span style="font-weight:400; color: var(--color-text-muted);">(if known)</span></label>
						<input type="number" id="soh" name="soh" min="0" max="100" step="0.1">
					</div>

					<div class="form-group">
						<label for="soh-date">Date SoH was measured</label>
						<input type="date" id="soh-date" name="sohDate" aria-describedby="soh-date-error" data-not-future>
						<span class="form-error" id="soh-date-error" role="alert" hidden>State of Health measurement date cannot be in the future.</span>
					</div>

					<div class="form-group">
						<label for="soh-mileage">Mileage at SoH measurement</label>
						<input type="number" id="soh-mileage" name="sohMileage" min="0" max="500000">
					</div>

					<div class="form-group">
						<label for="soh-source">Source of SoH reading</label>
						<select id="soh-source" name="sohSource">
							<option value="">Select source</option>
							<option value="dealer-report">Dealer report</option>
							<option value="diagnostic-app">Diagnostic app / OBD</option>
							<option value="service-paperwork">Service paperwork</option>
							<option value="jlr-communication">JLR communication</option>
							<option value="estimate-unsure">Estimate / unsure</option>
						</select>
					</div>
				</div>
			</fieldset>

			<div class="step-nav">
				<button type="button" class="btn btn--secondary" data-prev>← Back</button>
				<button type="submit" class="btn btn--primary" data-submit>Save vehicle basics</button>
			</div>
		</div>

		<div class="submit-result" data-submit-result tabindex="-1" role="status">
			<div style="text-align: center; padding: var(--space-4);">
				<div style="font-size: 3rem; margin-bottom: var(--space-4);" aria-hidden="true" data-database-result-icon>⏳</div>
				<h2>Vehicle basics</h2>

				<div data-database-success hidden>
					<p style="color: var(--color-text-muted);">
						Your vehicle basics have been saved. Reference:
						<strong data-database-submission-id>saved</strong>.
					</p>
				</div>

				<div data-database-auth-error hidden>
					<p style="color: var(--color-danger);">
						Please sign in and submit the form again so the vehicle can be linked to your account.
					</p>
					<a class="btn btn--primary" href="/account/">Sign in</a>
				</div>

				<div data-database-error hidden>
					<p style="color: var(--color-danger);">
						<span data-database-error-message>We could not save the vehicle basics right now.</span>
						Please try again later or contact
						<a href="mailto:contact@ipace-owners.org">contact@ipace-owners.org</a>.
					</p>
				</div>

				<div class="cluster" style="justify-content:center; margin-top: var(--space-4);" data-database-success-actions hidden>
					<a href="/member/dashboard/" class="btn btn--primary">My Data</a>
					<a href="/submit-vehicle-data/" class="btn btn--secondary">Add another vehicle</a>
					<a href="/evidence-dashboard/" class="btn btn--secondary">View Evidence Dashboard</a>
				</div>
				<div class="cluster" style="justify-content:center; margin-top: var(--space-4);" data-database-error-actions hidden>
					<a href="/submit-vehicle-data/" class="btn btn--secondary">Try again</a>
					<a href="/member/dashboard/" class="btn btn--secondary">My Data</a>
				</div>
			</div>
		</div>
	</form>

	<div class="callout callout--info" style="margin-top: var(--space-8);">
		<span class="callout__icon" aria-hidden="true">ℹ️</span>
		<div class="callout__content">
			<p class="callout__title">Vehicle data starts here</p>
			<p>Register one I-PACE with vehicle identity, ownership dates, mileage, and optional
			battery State of Health details. After saving, use My Data to add further SoH readings
			and service or fault history for that vehicle.</p>
			<p>Campaign involvement, fault duration, courtesy vehicle, parts delay, warranty cover,
			and dispute details can be added from My Data as service or fault records. Payment,
			goodwill, and evidence upload fields will be added as the evidence workflow expands.
			Add one vehicle at a time; you can return here to register another I-PACE.</p>
			<p style="margin-bottom:0;">Full VINs are not stored. If provided, the VIN is converted
			to a server-side HMAC for deduplication, and only the final six characters are kept
			for member-facing reference.</p>
		</div>
	</div>
</div>
