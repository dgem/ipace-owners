      </div>
    </div>

    <div class="step-nav">
      <button type="button" class="btn btn--secondary" data-prev>← Back</button>
      <div class="step-nav__secondary">
        <button type="button" class="btn btn--ghost" style="color:var(--color-text-muted); border-color:var(--color-border);">Save for later <span style="font-size:0.75em;">(coming soon)</span></button>
      </div>
      <button type="submit" class="btn btn--primary" data-submit>Submit vehicle data</button>
    </div>
  </div>

  <!-- Submission result -->
  <div class="submit-result" data-submit-result tabindex="-1" role="status">
    <div style="text-align: center; padding: var(--space-4);">
      <div style="font-size: 3rem; margin-bottom: var(--space-4);" aria-hidden="true">✅</div>
      <h2 style="color: var(--color-success);">Thank you for your submission</h2>
      <p style="color: var(--color-text-muted);">
