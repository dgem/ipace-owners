---
layout: base.njk
title: Admin Review Queue
description: "Admin review queue — I-PACE Owners' Advocacy Group."
permalink: /admin/review-queue/
---

<div class="page-header">
	<div class="container">
			<p class="page-header__eyebrow">Admin</p>
			<h1 class="page-header__title">Review Queue</h1>
	</div>
</div>

<div class="section">
	<div class="container">

				<!-- Server-side auth container: member-auth.js verifies via /.netlify/functions/admin-data -->
				<div data-admin-container>

					<!-- Login gate — shown by default when server confirms not authenticated -->
					<div class="auth-gate" data-auth-login-gate>
						<div class="auth-gate__icon" aria-hidden="true">🔒</div>
						<h2 class="auth-gate__title">Sign in required</h2>
						<p class="auth-gate__body">Enter your admin email address and we will send a secure sign-in link.</p>
						<form class="magic-link-form" data-magic-link-form>
							<label for="admin-magic-email">Email address</label>
							<input id="admin-magic-email" name="email" type="email" autocomplete="email" required>
							<button class="btn btn--primary full-width" type="submit">Email me a sign-in link</button>
							<p class="form-hint" data-magic-link-status role="status" aria-live="polite"></p>
						</form>
					</div>

					<!-- Logged in, no admin role — shown when server confirms auth but not admin -->
					<div class="auth-gate" data-admin-only-gate hidden>
						<div class="auth-gate__icon" aria-hidden="true">⛔</div>
						<h2 class="auth-gate__title">Access restricted</h2>
						<p class="auth-gate__body">
							This page is for group administrators only. If you believe you should have admin access,
							please contact us.
						</p>
						<a href="/contact/" class="btn btn--secondary">Contact us</a>
					</div>

					<!-- Admin content — revealed by member-auth.js after server confirms admin role -->
					<div class="auth-content" data-admin-content hidden>

						<div class="callout callout--warning" style="margin-bottom: var(--space-8);">
							<span class="callout__icon" aria-hidden="true">⚠️</span>
							<div class="callout__content">
								<p class="callout__title">Admin review queue — live data</p>
								<p>Data below is fetched server-side from the admin-data Netlify Function. Only users with the admin role can access this endpoint.</p>
							</div>
						</div>

						<!-- Stats populated by member-auth.js -->
						<div class="dashboard-panel">
							<div class="dashboard-panel__header">
								<h2 class="dashboard-panel__title">Overview</h2>
							</div>
							<div data-stats-container>
								<p style="color:var(--color-text-muted);">Loading...</p>
							</div>
						</div>

						<!-- Join submissions table -->
						<div class="dashboard-panel" style="margin-top: var(--space-6);">
							<div class="dashboard-panel__header">
								<h2 class="dashboard-panel__title">Join Submissions</h2>
							</div>
							<div data-join-table-container>
								<p style="color:var(--color-text-muted);">Loading...</p>
							</div>
						</div>

						<!-- Vehicle records table -->
						<div class="dashboard-panel" style="margin-top: var(--space-6);">
							<div class="dashboard-panel__header">
								<h2 class="dashboard-panel__title">Vehicle Records</h2>
							</div>
							<div data-vehicle-table-container>
								<p style="color:var(--color-text-muted);">Loading...</p>
							</div>
						</div>

						<div style="margin-top: var(--space-6);">
							<h2>Admin navigation</h2>
							<div class="cluster">
								{% for item in navigation.admin %}
									<a href="{{ item.url }}" class="btn btn--secondary btn--sm">{{ item.label }}</a>
								{% endfor %}
							</div>
						</div>
					</div>
				</div>

	</div>
</div>
