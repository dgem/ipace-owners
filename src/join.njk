---
layout: form-page.njk
title: Join the Group
eyebrow: Membership
subtitle: "Free to join. Takes less than a minute."
description: "Add your voice to the I-PACE Owners' Advocacy Group — free membership, no obligation."
multiStepForm: true
formPageWide: true
compactHeader: true
compactSection: true
---

<div class="form-workspace" data-site-mode-only="launch">
  <form
    class="form form--compact"
    name="join-launch"
    method="POST"
    action="/api/submit-join"
    data-multistep-form
    data-database-submit="/api/submit-join"
    novalidate
    aria-label="Join the I-PACE Owners' Group"
  >
    <p class="visually-hidden">
      <label>Do not fill this in if you are human: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
    </p>

    <div data-step="1">
      <h2 class="step-heading" data-step-heading tabindex="-1">Your membership details</h2>

      <fieldset>
        <legend>Add your voice</legend>

        <div class="form-grid form-grid--2">
          <div class="form-group">
            <label for="launch-join-name">Full name <span aria-hidden="true">*</span></label>
            <span class="form-hint" id="launch-join-name-hint">How you'd like to be addressed</span>
            <input
              type="text"
              id="launch-join-name"
              name="name"
              required
              autocomplete="name"
              aria-describedby="launch-join-name-hint launch-join-name-error"
            >
            <span class="form-error" id="launch-join-name-error" role="alert"></span>
          </div>

          <div class="form-group">
            <label for="launch-join-email">Email address <span aria-hidden="true">*</span></label>
            <span class="form-hint" id="launch-join-email-hint">We'll use this to contact you about the group</span>
            <input
              type="email"
              id="launch-join-email"
              name="email"
              required
              autocomplete="email"
              aria-describedby="launch-join-email-hint launch-join-email-error"
            >
            <span class="form-error" id="launch-join-email-error" role="alert"></span>
          </div>
        </div>

        <div class="check-group">
          <label class="check-label">
            <input type="checkbox" name="consent-contact" value="yes" required>
            I agree to be contacted about the I-PACE Owners' Group. <span aria-hidden="true">*</span>
          </label>
          <label class="check-label">
            <input type="checkbox" name="consent-not-legal" value="yes" required>
            I understand that joining does not enrol me in legal action or create a legal
            relationship. <span aria-hidden="true">*</span>
          </label>
          <label class="check-label">
            <input type="checkbox" name="consent-data" value="yes">
            I agree that information I choose to share can be shown on the I-PACE Owners
            site in anonymised aggregate form.
          </label>
        </div>

        <p class="form-hint join-privacy-note">See our <a href="/privacy/">Privacy Policy</a>
        and <a href="/terms/">Participation Statement</a>.</p>
      </fieldset>

      <div class="step-nav join-launch-submit">
        <button
          type="submit"
          class="btn btn--primary btn--lg"
          data-submit
          data-enable-when-checked="consent-contact consent-not-legal"
          disabled
        >Join the Group</button>
      </div>
    </div>

    {% include "partials/join-result.njk" %}
  </form>

  <aside class="form-workspace__aside" aria-label="What happens after joining">
    <div class="callout callout--info">
      <span class="callout__icon" aria-hidden="true">ℹ️</span>
      <div class="callout__content">
        <p class="callout__title">What happens next</p>
        <p>We save your membership securely and email you a sign-in link. We are only asking
        owners to register now; if we need vehicle details later, we will explain why and ask
        separately.</p>
      </div>
    </div>
  </aside>
</div>

<div class="form-workspace" data-site-mode-only="full">

<form
  class="form form--compact"
  name="join"
  method="POST"
  action="/api/submit-join"
  data-multistep-form
  data-database-submit="/api/submit-join"
  novalidate
  aria-label="Join the I-PACE Owners' Group"
>
  <p class="visually-hidden">
    <label>Do not fill this in if you are human: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
  </p>

  <!-- Progress indicator -->
  <div class="progress-indicator" data-progress aria-live="polite" aria-atomic="true">
    <div class="progress-indicator__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100">
      <div class="progress-indicator__fill" data-progress-fill style="width: 25%;"></div>
    </div>
    <div class="progress-indicator__text">
      <span data-progress-text>Step 1 of 4</span>
      <span>Join form</span>
    </div>
  </div>

  <!-- Step 1: Contact details -->
  <div data-step="1">
    <h2 class="step-heading" data-step-heading tabindex="-1">Contact details</h2>

    <fieldset>
      <legend>Your contact information</legend>

      <div class="form-grid form-grid--2">
      <div class="form-group">
        <label for="join-name">Full name <span aria-hidden="true">*</span></label>
        <span class="form-hint" id="join-name-hint">How you'd like to be addressed</span>
        <input
          type="text"
          id="join-name"
          name="name"
          required
          autocomplete="name"
          aria-describedby="join-name-hint join-name-error"
        >
        <span class="form-error" id="join-name-error" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="join-email">Email address <span aria-hidden="true">*</span></label>
        <span class="form-hint" id="join-email-hint">We'll use this to contact you about the group</span>
        <input
          type="email"
          id="join-email"
          name="email"
          required
          autocomplete="email"
          aria-describedby="join-email-hint join-email-error"
        >
        <span class="form-error" id="join-email-error" role="alert"></span>
      </div>
      </div>

      <div class="form-group">
        <label for="join-country">Country / region</label>
        <select id="join-country" name="country" aria-describedby="join-country-hint">
          <option value="">Select a country</option>
          <option value="GB" selected>United Kingdom</option>
          <option value="IE">Ireland</option>
          <option value="DE">Germany</option>
          <option value="FR">France</option>
          <option value="NL">Netherlands</option>
          <option value="NO">Norway</option>
          <option value="SE">Sweden</option>
          <option value="DK">Denmark</option>
          <option value="AT">Austria</option>
          <option value="CH">Switzerland</option>
          <option value="BE">Belgium</option>
          <option value="ES">Spain</option>
          <option value="IT">Italy</option>
          <option value="PT">Portugal</option>
          <option value="US">United States</option>
          <option value="CA">Canada</option>
          <option value="AU">Australia</option>
          <option value="NZ">New Zealand</option>
          <option value="other">Other</option>
        </select>
        <span class="form-hint" id="join-country-hint">This is a UK-led initiative; non-UK interest is recorded separately where useful</span>
      </div>
    </fieldset>

    <div class="step-nav">
      <button type="button" class="btn btn--secondary" data-prev style="visibility:hidden">Back</button>
      <button type="button" class="btn btn--primary" data-next>Next: Ownership →</button>
    </div>
  </div>

  <!-- Step 2: Ownership status -->
  <div data-step="2" class="step--hidden">
    <h2 class="step-heading" data-step-heading tabindex="-1">Ownership status</h2>

    <fieldset>
      <legend>Your relationship to an I-PACE</legend>

      <div class="form-group">
        <label>Your ownership or interest</label>
        <div class="radio-group" role="radiogroup" aria-labelledby="join-relationship-label">
          <p id="join-relationship-label" class="form-hint">Choose the single option that best describes your current position.</p>

          <label class="radio-label">
            <input type="radio" name="relationship" value="current-owner-one"> I currently own one I-PACE
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="current-owner-multiple"> I currently own more than one I-PACE
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="former-owner"> I used to own an I-PACE
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="prospective-buyer"> I am considering buying one
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="helping-owner"> I am helping an owner
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="trade-specialist"> Trade / specialist
          </label>
          <label class="radio-label">
            <input type="radio" name="relationship" value="other"> Other
          </label>
        </div>
      </div>
    </fieldset>

    <div class="step-nav">
      <button type="button" class="btn btn--secondary" data-prev>← Back</button>
      <button type="button" class="btn btn--primary" data-next>Next: Skills →</button>
    </div>
  </div>

  <!-- Step 3: Skills / volunteering -->
  <div data-step="3" class="step--hidden">
    <h2 class="step-heading" data-step-heading tabindex="-1">Skills and volunteering</h2>

    <fieldset>
      <legend>Would you like to help run the group?</legend>
      <p class="form-hint">Select any that apply — entirely optional</p>

      <div class="check-group">
        <label class="check-label">
          <input type="checkbox" name="skills" value="legal"> Legal
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="technical"> Technical / battery expertise
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="data"> Data analysis
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="media"> Media / PR
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="web"> Web / admin
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="consumer-rights"> Consumer rights
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="dealer"> Dealer contacts
        </label>
        <label class="check-label">
          <input type="checkbox" name="skills" value="general"> General volunteering
        </label>
      </div>
    </fieldset>

    <div class="step-nav">
      <button type="button" class="btn btn--secondary" data-prev>← Back</button>
      <button type="button" class="btn btn--primary" data-next>Next: Consent →</button>
    </div>
  </div>

  <!-- Step 4: Consent and review -->
  <div data-step="4" class="step--hidden">
    <h2 class="step-heading" data-step-heading tabindex="-1">Consent and review</h2>

    <fieldset>
      <legend>Please read and confirm</legend>

      <div class="check-group">
        <label class="check-label">
          <input type="checkbox" name="consent-contact" value="yes" required>
          I agree to be contacted about the I-PACE Owners' Group. <span aria-hidden="true">*</span>
        </label>
        <label class="check-label">
          <input type="checkbox" name="consent-not-legal" value="yes" required>
          I understand that joining this group is not currently a legal claim and creates no
          legal relationship. <span aria-hidden="true">*</span>
        </label>
        <label class="check-label">
          <input type="checkbox" name="consent-data" value="yes">
          I consent to my submitted data being used in anonymised aggregate analysis.
        </label>
      </div>

      <div class="callout callout--info" style="margin-top: var(--space-5);">
        <span class="callout__icon" aria-hidden="true">📋</span>
        <div class="callout__content">
          <p>By submitting this form you confirm that the information you have provided is
          accurate to the best of your knowledge. See our
          <a href="/privacy/">Privacy Policy</a> and
          <a href="/terms/">Participation Statement</a>.</p>
        </div>
      </div>
    </fieldset>

    <div class="step-nav">
      <button type="button" class="btn btn--secondary" data-prev>← Back</button>
      <div></div>
      <button
        type="submit"
        class="btn btn--primary"
        data-submit
        data-enable-when-checked="consent-contact consent-not-legal"
        disabled
      >Join the Group</button>
    </div>
  </div>

  {% include "partials/join-result.njk" %}

</form>

  <aside class="form-workspace__aside" aria-label="Join form status">
    <div class="callout callout--info">
      <span class="callout__icon" aria-hidden="true">ℹ️</span>
      <div class="callout__content">
        <p class="callout__title">Membership details are saved</p>
            <p>At the end, your membership details are saved securely and we ask our sign-in
            provider to email the address you provide. Once you confirm the link, you can
            optionally add vehicle details, State of Health readings, and service or fault
            history for one or more I-PACEs.</p>
      </div>
    </div>
  </aside>
</div>
