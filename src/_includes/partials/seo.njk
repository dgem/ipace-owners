{% set seoTitle = site.title if page.url == "/" else (title + " — " + site.title if title else site.title) %}
{% set seoDescription = description or summary or site.description %}
{% set canonicalUrl = canonical or (site.url + page.url) %}
{% set seoImageUrl = socialImage or (site.url + site.socialImage) %}
{% set seoImageDescription = socialImageAlt or site.socialImageAlt %}
<title>{{ seoTitle }}</title>
<meta name="description" content="{{ seoDescription }}">
<meta name="robots" content="{% if noindex %}noindex, nofollow{% else %}index, follow{% endif %}">
<link rel="canonical" href="{{ canonicalUrl }}">

<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:type" content="{{ seoType or 'website' }}">
<meta property="og:locale" content="en_GB">
<meta property="og:title" content="{{ seoTitle }}">
<meta property="og:description" content="{{ seoDescription }}">
<meta property="og:url" content="{{ canonicalUrl }}">
<meta property="og:image" content="{{ seoImageUrl }}">
<meta property="og:image:alt" content="{{ seoImageDescription }}">
{% if seoType == "article" and date %}<meta property="article:published_time" content="{{ date | isoDate }}">{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seoTitle }}">
<meta name="twitter:description" content="{{ seoDescription }}">
<meta name="twitter:image" content="{{ seoImageUrl }}">
<meta name="twitter:image:alt" content="{{ seoImageDescription }}">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ site.url }}/#organization",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}/",
      "logo": "{{ site.url }}{{ site.logo }}",
      "email": "{{ site.email }}"
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.url }}/#website",
      "url": "{{ site.url }}/",
      "name": "{{ site.title }}",
      "description": "{{ site.description }}",
      "publisher": { "@id": "{{ site.url }}/#organization" },
      "inLanguage": "en-GB"
    }
  ]
}
</script>
