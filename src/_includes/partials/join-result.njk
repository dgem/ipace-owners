<div class="submit-result join-result" data-submit-result tabindex="-1" role="status">
  <div class="join-result__inner">
    <span class="join-result__icon" aria-hidden="true"></span>
    <h2 class="join-result__title">Thank you for joining</h2>

    <p class="text-muted" data-registration-signed-in hidden>
      You are already signed in. Your membership details have been submitted to the group.
    </p>

    <div class="join-result__summary" data-database-success hidden>
      <p><strong>Your membership details have been saved.</strong> Your support helps show
      that I-PACE owners are organised and ready to engage constructively.</p>
    </div>

    <div data-database-error hidden>
      <p class="join-result__error"><strong>We could not save your join form just now.</strong>
      Please try again or contact
      <a href="mailto:contact@ipace-owners.org">contact@ipace-owners.org</a>.</p>
    </div>

    <div data-registration-guest hidden>
      <div class="join-result__next-step" data-registration-link-sent hidden>
        <h3>Check your inbox</h3>
        <p>
          We’ve sent an email to
          <strong data-registration-email>you</strong>
          to verify your email address.
        </p>
        <p>
          When it arrives, use the secure button in the email to verify your account and sign in.
        </p>
        <p>
          Once signed in, you can add your vehicles and their data, and access all the
          features available to members.
        </p>
        <p class="join-result__note">
          Delivery can sometimes be delayed or filtered. Check your spam or junk folder,
          then use Sign in to request another link if it has not arrived.
        </p>
      </div>

      <div data-registration-error hidden>
        <p class="join-result__error"><strong>Your join details were saved, but we couldn't send your sign-in link.</strong></p>
        <p class="text-muted">Use the <strong>Sign in</strong> button in the header, or email us at
        <a href="mailto:contact@ipace-owners.org">contact@ipace-owners.org</a>.</p>
      </div>
    </div>
  </div>
</div>
