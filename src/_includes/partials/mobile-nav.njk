<nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" aria-hidden="false">
  <ul class="mobile-nav__list" role="list">
    {% for item in navigation.public %}
      <li{% if item.launchVisible == false %} data-site-mode-only="full"{% endif %}>
        {% if item.highlight %}
          <a
            href="{{ item.url }}"
            class="mobile-nav__link mobile-nav__link--highlight"
            data-nav-link
            data-requires-guest
          >{{ item.label }}</a>
        {% else %}
          <a
            href="{{ item.url }}"
            class="mobile-nav__link"
            data-nav-link
          >{{ item.label }}</a>
        {% endif %}
      </li>
    {% endfor %}
  </ul>

  <div class="mobile-nav__identity">
    <a href="/member/dashboard/" class="btn btn--sm btn--primary full-width" data-requires-auth style="display:none">My Data</a>
    <a href="/member/account/" class="btn btn--sm btn--secondary full-width" data-requires-auth style="display:none">My account</a>
    <a href="/admin/outreach/" class="btn btn--sm btn--secondary full-width" data-requires-admin style="display:none">Admin tools</a>
    <a id="identity-mobile-login-btn" class="btn btn--sm btn--secondary full-width" href="/member/account/">Sign in</a>
    <button id="identity-mobile-logout-btn" class="btn btn--sm btn--ghost full-width" type="button" style="display:none">Sign out</button>
  </div>
</nav>
