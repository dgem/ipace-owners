<!DOCTYPE html>
<html lang="en" data-site-mode="{{ site.defaultMode or 'launch' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/seo.njk" %}
  <meta name="theme-color" content="#12324a">
  <link rel="icon" href="/favicon.png" type="image/png">

  {# Critical fail-closed mode CSS: hide full-mode content unless full mode is explicit. #}
  <style>
    :root:not([data-site-mode="full"]) [data-site-mode-only="full"],
    :root[data-site-mode="full"] [data-site-mode-only="launch"] {
      display: none !important;
    }
  </style>

  {# Synchronous by design: set the requested mode before the main stylesheet renders. #}
  <script src="/assets/js/site-mode.js"></script>

  {% if firebase.apiKey %}
  <script>
    window.ipaceFirebaseConfig = {
      apiKey: "{{ firebase.apiKey }}",
      authDomain: "{{ firebase.authDomain }}",
      projectId: "{{ firebase.projectId }}",
      appId: "{{ firebase.appId }}",
      storageBucket: "{{ firebase.storageBucket }}"
    };
  </script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-auth-compat.js"></script>
  {% endif %}

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/site.css">

  <!-- Preload key assets -->
  <link rel="preconnect" href="https://www.gstatic.com">
  <link rel="preconnect" href="https://identitytoolkit.googleapis.com">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}{% if authRedirectOnLogin %} data-auth-redirect-on-login="{{ authRedirectOnLogin }}"{% endif %}{% if authRedirectOnLogout %} data-auth-redirect-on-logout="{{ authRedirectOnLogout }}"{% endif %}>

  <!-- Skip navigation -->
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <!-- Site header -->
  {% include "partials/header.njk" %}

  <!-- Mobile nav drawer -->
  {% include "partials/mobile-nav.njk" %}

  <!-- Main content -->
  <main id="main-content" tabindex="-1">
    {% if fullModeOnly %}
    <section class="section" data-site-mode-only="launch">
      <div class="container container--narrow">
        <div class="callout callout--info launch-unavailable" role="status">
          <span class="callout__icon" aria-hidden="true">ℹ️</span>
          <div class="callout__content">
            <p class="callout__title">This section is not part of the public launch</p>
            <p>We are keeping the launch site focused on bringing owners together. Existing members can still sign in and use their private account tools.</p>
            <p><a class="btn btn--primary" href="/">Return to the homepage</a></p>
          </div>
        </div>
      </div>
    </section>
    <div data-site-mode-only="full">
      {{ content | safe }}
    </div>
    {% else %}
      {{ content | safe }}
    {% endif %}
  </main>

  <!-- Site footer -->
  {% include "partials/footer.njk" %}

  <div class="cookie-notice" data-cookie-notice hidden>
    <div class="cookie-notice__content">
      <p class="cookie-notice__title">Cookies and privacy</p>
      <p>
        We use essential cookies only for sign-in and to remember this notice. No analytics
        or advertising cookies.
      </p>
    </div>
    <div class="cookie-notice__actions">
      <a href="/privacy/" class="btn btn--sm btn--ghost">Privacy</a>
      <button type="button" class="btn btn--sm btn--primary" data-cookie-accept>OK</button>
    </div>
  </div>
  <noscript>
    <div class="cookie-notice cookie-notice--noscript">
      <div class="cookie-notice__content">
        <p class="cookie-notice__title">Cookies and privacy</p>
        <p>
          We use essential site services only. Firebase Authentication may use cookies
          or browser storage for sign-in. We do not use analytics or advertising
          cookies.
        </p>
      </div>
      <div class="cookie-notice__actions">
        <a href="/privacy/" class="btn btn--sm btn--ghost">Privacy</a>
      </div>
    </div>
  </noscript>

  <!-- Scripts -->
  <script src="/assets/js/main.js" defer></script>
  <script src="/assets/js/identity.js" defer></script>
  <script src="/assets/js/member-auth.js" defer></script>
  <script src="/assets/js/member-dashboard.js" defer></script>
  <script src="/assets/js/public-stats.js" defer></script>
  {% if multiStepForm %}
  <script src="/assets/js/multistep-form.js" defer></script>
  {% endif %}
  {% if outreachAssistant %}
  <script src="/assets/js/outreach-assistant.js" defer></script>
  {% endif %}
  {% if emailCampaigns %}
  <script src="/assets/js/email-campaigns.js" defer></script>
  {% endif %}
  {% if instagramCampaigns %}
  <script src="/assets/js/instagram-campaigns.js" defer></script>
  {% endif %}
</body>
</html>
