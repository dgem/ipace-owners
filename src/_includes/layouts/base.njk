<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.description }}">
  <meta name="theme-color" content="#12324a">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- Netlify Identity Widget -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/site.css">

  <!-- Preload key assets -->
  <link rel="preconnect" href="https://identity.netlify.com">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}{% if authRedirectOnLogin %} data-auth-redirect-on-login="{{ authRedirectOnLogin }}"{% endif %}{% if authRedirectOnLogout %} data-auth-redirect-on-logout="{{ authRedirectOnLogout }}"{% endif %}>

  <!-- Skip navigation -->
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <!-- Site header -->
  {% include "partials/header.njk" %}

  <!-- Mobile nav drawer -->
  {% include "partials/mobile-nav.njk" %}

  <!-- Main content -->
  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  <!-- Site footer -->
  {% include "partials/footer.njk" %}

  <div class="cookie-notice" data-cookie-notice hidden>
    <div class="cookie-notice__content">
      <p class="cookie-notice__title">Cookies and privacy</p>
      <p>
        We use essential site services only. Netlify Identity may use cookies or
        browser storage for sign-in, and this notice stores your choice. We do
        not use analytics or advertising cookies.
      </p>
    </div>
    <div class="cookie-notice__actions">
      <a href="/privacy/" class="btn btn--sm btn--ghost">Privacy</a>
      <button type="button" class="btn btn--sm btn--primary" data-cookie-accept>OK</button>
    </div>
  </div>
  <noscript>
    <div class="cookie-notice cookie-notice--noscript">
      <div class="cookie-notice__content">
        <p class="cookie-notice__title">Cookies and privacy</p>
        <p>
          We use essential site services only. Netlify Identity may use cookies
          or browser storage for sign-in. We do not use analytics or advertising
          cookies.
        </p>
      </div>
      <div class="cookie-notice__actions">
        <a href="/privacy/" class="btn btn--sm btn--ghost">Privacy</a>
      </div>
    </div>
  </noscript>

  <!-- Scripts -->
  <script src="/assets/js/main.js" defer></script>
  <script src="/assets/js/identity.js" defer></script>   <script src="/assets/js/member-auth.js" defer></script>  {% if multiStepForm %}
  <script src="/assets/js/multistep-form.js" defer></script>
  {% endif %}
</body>
</html>
