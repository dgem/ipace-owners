---
layout: base.njk
multiStepForm: true
---
<div class="page-header{% if compactHeader %} page-header--compact{% endif %}">
  <div class="container">
    {% if eyebrow %}<p class="page-header__eyebrow">{{ eyebrow }}</p>{% endif %}
    <h1 class="page-header__title">{{ title }}</h1>
    {% if subtitle %}<p class="page-header__subtitle">{{ subtitle }}</p>{% endif %}
  </div>
</div>

<div class="section{% if compactSection %} section--sm{% endif %}">
  <div class="container{% if not formPageWide %} container--narrow{% endif %}">
    {{ content | safe }}
  </div>
</div>
